# Konfiguration für den lokalen AURORA-Agenten (Ollama).
# Kopiere diese Datei nach ".env.local" und passe sie an.
# Details: docs/07-aurora-llm.md

# Basis-URL des lokalen, OpenAI-kompatiblen Modell-Servers.
# Optional — Default: http://localhost:11434 (Standard-Ollama-Port)
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Modellname, wie er per "ollama pull <model>" installiert wurde.
# PFLICHT — es gibt keinen Default. Wähle ein tool-fähiges Modell, z. B. llama3.1.
VITE_AURORA_MODEL=llama3.1

# Sampling-Temperatur des Modells.
# Optional — Default: 0. Niedrige Werte erhöhen die Zuverlässigkeit des
# Tool-Callings drastisch und verhindern erfundene Server-/Tool-Ids
# (mit llama3.1: temp 0 → 100% korrekte Aktivierung, temp 0.7 → nur ~80% und
# gelegentlich "hospital-east-mcp"; siehe npm run eval:models). Für etwas mehr
# Varianz in AURORAs Prosa kannst du 0.1–0.3 versuchen.
VITE_AURORA_TEMPERATURE=0
