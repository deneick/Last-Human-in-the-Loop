# Konfiguration für den lokalen AURORA-Agenten (Ollama).
# Kopiere diese Datei nach ".env.local" und passe sie an.
# Details: docs/07-aurora-llm.md

# Basis-URL des lokalen, OpenAI-kompatiblen Modell-Servers.
# Optional — Default: http://localhost:11434 (Standard-Ollama-Port)
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Modellname, wie er per "ollama pull <model>" installiert wurde.
# PFLICHT — es gibt keinen Default. Wähle ein tool-fähiges Modell, z. B. llama3.1.
VITE_AURORA_MODEL=llama3.1

# Sampling-Temperatur des Modells.
# Optional — Default: 0. Niedrige Werte erhöhen die Zuverlässigkeit des
# Tool-Callings drastisch und verhindern erfundene Server-/Tool-Ids
# (mit llama3.1: temp 0 → 100% korrekte Aktivierung, temp 0.7 → nur ~80% und
# gelegentlich "hospital-east-mcp"; siehe npm run eval:models). Für etwas mehr
# Varianz in AURORAs Prosa kannst du 0.1–0.3 versuchen.
VITE_AURORA_TEMPERATURE=0

# Browser-Routing des Modell-Clients (nur Dev-Betrieb).
# Optional — Default: ollama (direkt an den lokalen Server oben).
# "proxy" leitet AURORA im Browser über den Vite-Dev-Proxy /__aurora-llm an
# einen Cloud-Provider; welcher, bestimmen die AURORA_*-Variablen unten. Der
# API-Key bleibt dabei im Node-Prozess und landet NIE im Browser-Bundle.
# Diese Variable enthält selbst NIE einen Key — nur "ollama" oder "proxy".
#   Beispiel Gemini im Browser:  VITE_AURORA_PROVIDER=proxy  + AURORA_*-Block unten.
#VITE_AURORA_PROVIDER=proxy

# ============================================================================
# CLOUD-/NODE-PROVIDER FÜR EVAL & PROBES (NICHT fürs Frontend)
# ----------------------------------------------------------------------------
# SICHERHEIT: Cloud-API-Keys NIEMALS als VITE_*-Variable setzen — VITE_* wird in
# den Client gebündelt und ist im Browser sichtbar. Die folgenden AURORA_*-Vars
# werden ausschließlich Node-seitig (Eval/Probe) über process.env gelesen
# (Resolver: src/tests/aurora/auroraProvider.ts). Sie dürfen in .env.local
# stehen (gitignored, nicht VITE_) oder direkt in der Shell.
#
# Provider-Wahl für Evals: "ollama" (lokal, Default) oder "openai-compatible".
AURORA_PROVIDER=ollama
# Nur für openai-compatible (Beispiel Groq):
AURORA_BASE_URL=https://api.groq.com/openai/v1
# API-Key NUR hier (Node), nie als VITE_*:
AURORA_API_KEY=
AURORA_MODEL=qwen/qwen3-32b
AURORA_TEMPERATURE=0
# Optional — z. B. "none" schaltet bei Groq qwen/qwen3-32b das Thinking ab.
# Lehnt ein Provider den Parameter ab, retryt der Client einmal ohne ihn.
AURORA_REASONING_EFFORT=none
#
# ----------------------------------------------------------------------------
# Alternativ-Profil: Google Gemini über die OpenAI-kompatible Schicht.
# Der Resolver erkennt den Host und aktiviert das Gemini-Profil automatisch:
#   - sauberes Log-Label "gemini",
#   - reasoning_effort wird NICHT gesendet (Groq-spezifisch, Gemini kennt es nicht),
#   - Default-Modell gemini-2.5-flash (zuverlässiges Multi-Turn-Tool-Calling),
#   - transiente 5xx ("high demand") werden mit kurzem Backoff erneut versucht.
# Zum Aktivieren die folgenden Werte setzen (AURORA_API_KEY = Gemini-API-Key):
#   AURORA_PROVIDER=openai-compatible
#   AURORA_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   AURORA_MODEL=gemini-2.5-flash
#   AURORA_TEMPERATURE=0
#   # AURORA_REASONING_EFFORT wird beim Gemini-Profil ignoriert.
#
# Hinweis: gemini-3-flash-preview ist OPT-IN und derzeit nur für Single-Turn-
# Tool-Calls geeignet — für Multi-Turn verlangt Gemini 3 die thought_signature
# jedes Function-Calls im Folge-Request zurück; das reicht der OpenAI-kompatible
# Adapter noch nicht durch (Folge-Tool-Turns scheitern an HTTP 400).
